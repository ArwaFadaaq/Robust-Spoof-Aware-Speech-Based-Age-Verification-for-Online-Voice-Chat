# =========================================================
# AUDIO FIX
# =========================================================

def pad_trim(audio, sr=SR, sec=TARGET_SEC):
    target_len = int(sr * sec)

    if isinstance(audio, str):
        audio, _ = librosa.load(audio, sr=sr)

    audio = np.asarray(audio).astype(np.float32)

    if len(audio) > target_len:
        audio = audio[:target_len]
    elif len(audio) < target_len:
        audio = np.pad(audio, (0, target_len - len(audio)))

    return audio


def save_audio(path, audio):
    audio = pad_trim(audio)
    os.makedirs(os.path.dirname(path), exist_ok=True)
    sf.write(path, audio, SR)

# =========================================================
# ENGINE BALANCE (33/33/33)
# =========================================================

def assign_engines(df, engines, rng):
    df = df.copy()
    df["spoof_engine"] = rng.choice(engines, size=len(df))
    return df

# =========================================================
# CROSS AGE (ONLY VC/TTS)
# =========================================================

def assign_cross_age(df, rng, p=0.5):
    df = df.copy()
    df["cross_age_spoof"] = rng.choice([True, False], size=len(df), p=[p, 1-p])
    return df


def assign_target_age(df):
    flip = {"adult": "minor", "minor": "adult"}

    df = df.copy()
    mask = df["cross_age_spoof"] == True

    df.loc[mask, "target_age_class"] = df.loc[mask, "source_age_class"].map(flip)
    df.loc[~mask, "target_age_class"] = df.loc[~mask, "source_age_class"]

    return df

# =========================================================
# TRANSCRIPT HANDLING (TTS ONLY)
# =========================================================

def filter_transcripts(src_df, tr_df):
    valid_ids = set(tr_df[tr_df["has_transcript"] == 1]["segment_id"])
    return src_df[src_df["segment_id"].isin(valid_ids)].copy()


def build_transcript_map(tr_df):
    return dict(zip(tr_df["segment_id"].astype(str), tr_df["sentence"]))

# =========================================================
# TARGET SAMPLING (VC / TTS ONLY)
# =========================================================

def sample_target(tgt_df, src_row, rng):
    pool = tgt_df[tgt_df["mapped_age_class"] == src_row["target_age_class"]]

    if len(pool) == 0:
        pool = tgt_df

    return pool.iloc[int(rng.integers(0, len(pool)))]

# =========================================================
# AGE DIRECTION
# =========================================================

def age_direction(src, tgt):
    if pd.isna(src) or pd.isna(tgt):
        return np.nan
    return f"{src[0]}2{tgt[0]}"

# =========================================================
# BUILD ROW (FIXED LOGIC)
# =========================================================

def build_row(row, final_path, transcript_map, kind):

    is_replay = (kind == "replay")
    is_tts = (kind == "tts")

    src_age = row["source_age_class"]
    tgt_age = row.get("target_age_class") if not is_replay else np.nan

    return {
        # IDs
        "source_seg_id": row["segment_id"],
        "parent_file_id": row["parent_file_id"],

        # time
        "start_sec": row["start_sec"],
        "end_sec": row["end_sec"],

        # paths
        "source_seg_path": row["seg_path"],
        "source_file_path": row["source_file_path"],

        # TARGET (ONLY VC/TTS)
        "target_file_path": None if is_replay else row.get("target_file_path"),

        # source info
        "source_speaker_id": row["speaker_id"],
        "source_gender": row.get("gender"),
        "dataset_source": row.get("dataset_source"),
        "source_age_class": src_age,

        # target info
        "target_speaker_id": None if is_replay else row.get("target_speaker_id"),
        "target_gender": None if is_replay else row.get("target_gender"),
        "target_age_class": None if is_replay else tgt_age,

        # labels
        "authenticity": "spoof",
        "spoof_type": kind,
        "spoof_engine": row["spoof_engine"],

        # logic (STRICT RULE)
        "cross_age_spoof": None if is_replay else row.get("cross_age_spoof"),
        "age_direction": None if is_replay else age_direction(src_age, tgt_age),

        # transcript (ONLY TTS)
        "source_transcript_id": row["parent_file_id"] if is_tts else np.nan,
        "source_transcript": transcript_map.get(str(row["segment_id"])) if is_tts else np.nan,

        # dataset
        "split": row.get("split"),
        "source_pool": row.get("pool"),
        "target_pool": None if is_replay else row.get("target_pool"),

        # audio
        "is_clipped": None,
        "final_seg_path": final_path
    }

# =========================================================
# VALIDATION
# =========================================================

def validate_audio(audio, sr=SR):
    if audio is None:
        return False
    audio = np.asarray(audio)
    if len(audio) == 0:
        return False
    if np.max(np.abs(audio)) < 1e-6:
        return False
    return True

# =========================================================
# HELPERS
# =========================================================

def retry_if_invalid(fn, *args, retries=2):
    for _ in range(retries):
        out = fn(*args)
        if validate_audio(out):
            return out
    return None


