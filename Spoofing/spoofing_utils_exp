# =========================================
# LOAD DATA
# =========================================

def load_all(source_csv, target_csv, transcript_csv):
    src = pd.read_csv(source_csv)
    tgt = pd.read_csv(target_csv)
    tr  = pd.read_csv(transcript_csv)

    # normalize
    src["speaker_id"] = src["speaker_id"].astype(str)
    tgt["speaker_id"] = tgt["speaker_id"].astype(str)

    # age
    src["source_age_class"] = src["mapped_age_class"].str.lower()
    tgt["target_age_class"] = tgt["mapped_age_class"].str.lower()

    # transcript lookup
    transcript_lookup = dict(zip(tr["segment_id"].astype(str),
                                 tr["sentence"]))

    return src, tgt, transcript_lookup

# =========================================
# AUDIO
# =========================================

def is_valid_audio(audio):
    if audio is None:
        return False
    audio = np.asarray(audio)
    if len(audio) < 1000:
        return False
    if np.all(audio == 0):
        return False
    return True

def fix_length(audio):
    audio = np.asarray(audio).astype(np.float32)

    if len(audio) > TARGET_LEN:
        audio = audio[:TARGET_LEN]
    elif len(audio) < TARGET_LEN:
        audio = np.pad(audio, (0, TARGET_LEN - len(audio)))

    return audio

def save_audio(path, audio):
    os.makedirs(os.path.dirname(path), exist_ok=True)
    sf.write(path, audio, SR)

# =========================================
# RETRY
# =========================================

def generate_with_retry(generate_fn, max_try=3):
    for _ in range(max_try):
        audio = generate_fn()
        if is_valid_audio(audio):
            return audio
    return None

# =========================================
# BALANCING (VECTORISED)
# =========================================

def balanced_assign(n, items, rng):
    arr = (items * ((n // len(items)) + 1))[:n]
    rng.shuffle(arr)
    return arr

# =========================================
# TRAIN / VAL SAMPLING
# =========================================

def assign_train_val(df, engines_map, rng, cross_prob=0.8):
    
    # ===== spoof_type (33/33/33) =====
    df["spoof_type"] = balanced_assign(len(df), ["vc","tts","replay"], rng)

    # ===== remove TTS without transcript =====
    df = df[~((df["spoof_type"]=="tts") & (df["has_transcript"]!=1))]

    # ===== engines =====
    for t, engines in engines_map.items():
        mask = df["spoof_type"] == t
        df.loc[mask, "spoof_engine"] = balanced_assign(mask.sum(), engines, rng)

    # ===== cross-age =====
    df["cross_age_spoof"] = np.random.choice(
        [True, False], size=len(df), p=[cross_prob, 1-cross_prob]
    )

    # ===== target age =====
    flip = {"adult":"minor","minor":"adult"}
    df["target_age_class"] = df["source_age_class"]

    mask = df["cross_age_spoof"] == True
    df.loc[mask,"target_age_class"] = df.loc[mask,"source_age_class"].map(flip)

    return df

# =========================================
# TEST SAMPLING
# =========================================

def assign_test(df, TEST_TYPE, engines, rng):

    df["spoof_type"] = TEST_TYPE

    if TEST_TYPE == "tts":
        df = df[df["has_transcript"] == 1]

    df["spoof_engine"] = balanced_assign(len(df), engines, rng)

    if TEST_TYPE != "replay":
        df["cross_age_spoof"] = np.random.choice(
            [True, False], size=len(df), p=[0.5,0.5]
        )

        flip = {"adult":"minor","minor":"adult"}
        df["target_age_class"] = df["source_age_class"]

        mask = df["cross_age_spoof"] == True
        df.loc[mask,"target_age_class"] = df.loc[mask,"source_age_class"].map(flip)

    return df

# =========================================
# TARGET SELECTION
# =========================================

def select_targets(df, tgt):

    rows = []

    for _, r in df.iterrows():

        if r["spoof_type"] == "replay":
            rows.append({})
            continue

        pool = tgt[
            (tgt["mapped_age_class"] == r["target_age_class"]) &
            (tgt["split"] == r["split"]) &
            (tgt["speaker_id"] != r["speaker_id"])
        ]

        if len(pool) == 0:
            rows.append({})
            continue

        choice = pool.sample(1).iloc[0]

        rows.append({
            "target_speaker_id": choice["speaker_id"],
            "target_gender": choice.get("gender"),
            "target_pool": choice.get("pool"),
            "target_file_path": choice.get("processed_path"),
        })

    return pd.concat([df.reset_index(drop=True), pd.DataFrame(rows)], axis=1)

